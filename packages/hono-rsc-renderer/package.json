{
  "name": "@yoshikouki/hono-rsc-renderer",
  "version": "0.0.0",
  "description": "React Server Components renderer middleware for Hono",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf ./dist && bun build ./src/index.ts ./src/entry.ssr.ts ./src/entry.browser.ts --outdir ./dist --target browser --format esm --external hono --external react --external react-dom --external @vitejs/plugin-rsc && tsc -p tsconfig.json --emitDeclarationOnly",
    "typecheck": "tsc -p tsconfig.type-tests.json",
    "test": "bun test"
  },
  "exports": {
    ".": "./src/index.ts",
    "./entry.browser": "./src/entry.browser.ts",
    "./entry.ssr": "./src/entry.ssr.ts",
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./entry.browser": {
        "types": "./dist/entry.browser.d.ts",
        "import": "./dist/entry.browser.js"
      },
      "./entry.ssr": {
        "types": "./dist/entry.ssr.d.ts",
        "import": "./dist/entry.ssr.js"
      },
      "./package.json": "./package.json"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yoshikouki/hono-kit.git",
    "directory": "packages/hono-rsc-renderer"
  },
  "homepage": "https://github.com/yoshikouki/hono-kit/tree/main/packages/hono-rsc-renderer",
  "peerDependencies": {
    "@vitejs/plugin-rsc": ">=0.5.15 <0.6.0",
    "hono": ">=4.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-rsc": "^0.5.27",
    "hono": "^4.12.30",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}
