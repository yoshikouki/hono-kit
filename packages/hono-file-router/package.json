{
  "name": "@yoshikouki/hono-file-router",
  "version": "0.0.0",
  "description": "File-based routing core for Hono",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf ./dist && bun build ./src/index.ts --outdir ./dist --target browser --format esm --external hono && tsc -p tsconfig.json --emitDeclarationOnly && bun run typecheck:dist",
    "typecheck": "tsc -p tsconfig.type-tests.json",
    "typecheck:dist": "tsc -p tsconfig.dist-type-tests.json",
    "test": "bun test"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yoshikouki/hono-kit.git",
    "directory": "packages/hono-file-router"
  },
  "homepage": "https://github.com/yoshikouki/hono-kit/tree/main/packages/hono-file-router",
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "devDependencies": {
    "hono": "^4.12.30",
    "typescript": "^7.0.2"
  }
}
